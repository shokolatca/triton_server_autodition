name: "classifier_us8k_cnn"
backend: "onnxruntime"
platform: "onnxruntime_onnx"
max_batch_size: 8

input [
  {
    name: "mel_spectrogram"
    data_type: TYPE_FP32
    dims: [ -1, 128 ]
  }
]

output [
  {
    name: "class_logits"
    data_type: TYPE_FP32
    dims: [ 10 ]
  }
]

instance_group [
  { count: 1, kind: KIND_CPU }
]
